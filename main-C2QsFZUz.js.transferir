itas lebih tinggi.","murekaV8":"Model musik AI generasi berikutnya dengan melodi yang lebih kaya, vokal yang ekspresif, dan emosi yang lebih dalam untuk lagu yang siap secara komersial.","veo31Fast":"Pembuatan video sinematik yang cepat dengan kepatuhan yang kuat dan gerakan yang konsisten.","veo31":"Generasi sinematik dengan sinkronisasi audio-visual asli.","sora2":"Pembuatan video yang cepat dan estetis yang dioptimalkan untuk media sosial."},"skuLabels":{"cacheReadToken":"Token Baca Cache","cacheWriteToken":"Token Tulis Cache","inputToken":"Token Masukan","outputToken":"Token Keluaran","imageCount":"Jumlah Gambar","videoCount":"Jumlah Video","audioCount":"Jumlah Audio","requestCount":"Jumlah Permintaan"},"skuExplanations":{"cacheReadToken":"Satu token baca cache berharga {{credits}} kredit per 1000 token.","cacheWriteToken":"Satu token tulis cache berharga {{credits}} kredit per 1000 token.","inputToken":"Satu token masukan berharga {{credits}} kredit per 1000 token.","outputToken":"Satu token keluaran berharga {{credits}} kredit per 1000 token.","imageCount":"Setiap pembuatan gambar {{resolution}} memerlukan biaya {{credits}} kredit.","videoCount":"Setiap pembuatan video {{resolution}} dikenakan biaya {{credits}} kredit.","audioCount":"Setiap pembuatan audio dikenakan biaya {{credits}} kredit.","requestCount":"Setiap permintaan dikenakan biaya {{credits}} kredit."},"modelSelector":{"autoName":"Otomatis","autoDescription":"Secara otomatis memilih model terbaik untuk permintaan Anda.","switchModel":"Ganti Model","speed":"Kecepatan","intelligence":"Intelijen","cost":"Biaya","costLevels":{"high":"Tinggi","medium":"Sedang","low":"Rendah"}},"searchPlaceholder":"Cari...","apiKeyLabel":"Kunci API"},"community":{"viewCommunity":"Lihat Komunitas"},"preview":{"previews":"Pratinjau","componentPreview":"Pratinjau Komponen","projectPreview":"Pratinjau Proyek","loading":"Memuat...","copied":"Disalin","copyPrompt":"Salin Perintah","useItNow":"Gunakan Sekarang","remix":"campuran