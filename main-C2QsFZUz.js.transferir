Preview":"Modèle haute efficacité de Google optimisé pour les cas d'utilisation à grand volume.","gpt54Pro":"Le modèle le plus avancé de OpenAI, s'appuyant sur l'architecture unifiée de GPT-5.4 avec des capacités de raisonnement améliorées pour les tâches complexes et à enjeux élevés.","claudeSonnet46":"Le modèle de classe Sonnet le plus performant d'Anthropic à ce jour, avec des performances de pointe en matière de codage, d'agents et de travail professionnel.","minimaxM25":"Un grand modèle de langage léger et de pointe, optimisé pour le codage, les flux de travail agents et le développement d'applications modernes.","gemini31ProPreview":"Gemini 3.1 Pro Preview est le modèle de raisonnement frontalier de Google.","gpt54":"Le dernier modèle frontière de OpenAI, offrant un raisonnement plus solide, des résultats de meilleure qualité et des performances fiables pour les tâches complexes du monde réel.","claudeOpus46":"Le modèle le plus puissant d'Anthropic pour le codage et les tâches professionnelles de longue durée.","claudeOpus45":"Le modèle Claude 4.5 le plus puissant d'Anthropic pour le raisonnement complexe, le codage et le travail professionnel à contexte élevé.","claudeSonnet45":"Suivi d'instructions claires et rédaction longue de haute qualité, bien adaptée aux tâches d'analyse et à forte teneur en contenu.","glm5":"Le modèle de base open source phare de Z.ai, conçu pour la conception de systèmes complexes et les flux de travail d'agents à long terme.","gpt52Pro":"Une variante GPT-5.2 de plus grande capacité adaptée aux flux de travail exigeants et au raisonnement de qualité professionnelle.","kimiK25":"Le modèle à contexte long de Moonshot est conçu pour une utilisation approfondie des outils, la génération de code et une compréhension approfondie des documents.","nanoBanana2":"Officiellement connu sous le nom de Gemini 3 Flash Image, il s'agit d'un modèle de pointe qui permet la génération et l'édition avancées d'images.","nanoBananaPro":"Sortie premium avec une logique profonde et un rendu de texte précis.","nanoBanana":"Génération d'images rapide et fiable conçue pour les flux de travail créatifs quotidiens.","seedream45":"Génération d'images de haute qualité et prêtes pour la production à un prix raisonnable.","seedance10Pro":"Génération vidéo rentable avec un mouvement stable et une cohérence claire des sujets.","sunoV5":"Comprend une composition intelligente, une mémoire persistante de voix et d'instruments et des performances sans compromis pour une génération de musique plus rapide et de meilleure qualité.","murekaV8":"Un modèle musical IA de nouvelle génération avec des mélodies plus riches, des voix expressives et des émotions plus profondes pour des morceaux prêts à être commercialisés.","veo31Fast":"Génération vidéo cinématographique rapide avec une forte adhésion rapide et un mouvement cohérent.","veo31":"Génération cinématographique avec synchronisation audiovisuelle native.","sora2":"Génération vidéo rapide et esthétique optimisée pour les médias sociaux."},"skuLabels":{"cacheReadToken":"Jeton de lecture du cache","cacheWriteToken":"Jeton d'écriture du cache","inputToken":"Jeton d'entrée","outputToken":"Jeton de sortie","imageCount":"Nombre d'images","videoCount":"Nombre de vidéos","audioCount":"Nombre audio","requestCount":"Nombre de demandes"},"skuExplanations":{"cacheReadToken":"Un jeton de lecture du cache coûte {{credits}} crédits pour 1 000 jetons.","cacheWriteToken":"Un jeton d'écriture de cache coûte {{credits}} crédits pour 1 000 jetons.","inputToken":"Un jeton d'entrée coûte {{credits}} crédits pour 1 000 jetons.","outputToken":"Un jeton de sortie coûte {{credits}} crédits pour 1 000 jetons.","imageCount":"Chaque génération d'image {{resolution}} coûte {{credits}} crédits.","videoCount":"Chaque génération de vidéo {{resolution}} coûte {{credits}} crédits.","audioCount":"Chaque génération audio coûte {{credits}} crédits.","requestCount":"Chaque demande coûte {{credits}} crédits."},"modelSelector